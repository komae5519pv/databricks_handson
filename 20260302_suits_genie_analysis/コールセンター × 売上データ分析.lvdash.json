{
  "datasets": [
    {
      "name": "dataset1",
      "displayName": "gd_dashboard_fact",
      "queryLines": [
        "SELECT * FROM komae_demo_v4.call_center.gd_dashboard_fact"
      ],
      "columns": [
        {
          "displayName": "返品率（％）",
          "description": "返品件数 / 注文件数。全体では約10%、LINEチャネルは15〜18%で突出して高い。",
          "expression": "SUM(CASE WHEN returned THEN 1 ELSE 0 END) / COUNT(*)"
        }
      ]
    },
    {
      "name": "e97e2643",
      "displayName": "call_log_detail",
      "queryLines": [
        "SELECT\n",
        "    call_date,            -- 通話日\n",
        "    purpose,              -- 問い合わせ目的（割引クレーム/返品交換/配送納期 等）\n",
        "    trouble_type,         -- トラブル要因（割引条件/サイズ/納期/品質/請求/なし）\n",
        "    urgency_level,        -- 緊急度（高/中/低）\n",
        "    resolution_status,    -- 解決状況（解決/未解決/エスカレーション）\n",
        "    operator_action,      -- オペレーターの対応内容\n",
        "    transcript_summary    -- 通話要約（ai_queryで事前生成、50文字以内）\n",
        "FROM komae_demo_v4.call_center.sv_call_analysis\n",
        "ORDER BY call_date DESC"
      ]
    }
  ],
